<!-- etudiants.ejs -->

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Management</title>
  </head>
  <body>
    <h1>Student Management</h1>

    <!-- Add Student Form -->
    <h2>Add Student</h2>
    <form action="/students/add" method="post">
      
      <div class="form-group">
        <label for="nom">Nom:</label>
        <input type="text" name="nom" required />
      </div>
      <div class="form-group">
      <label for="prenom">Prénom:</label>
      <input type="text" name="prenom" required />
</div>
      <div class="form-group">
      <label for="cin">CIN:</label>
      <input type="text" name="cin" required />
</div>
      <div class="form-group">
      <label for="numeroInscription">Numéro d'inscription:</label>
      <input type="text" name="numeroInscription" required />
</div>
      <div class="form-group">
      <label for="dateNaissance">Date de naissance:</label>
      <input type="date" name="dateNaissance" required />
</div>
      <div class="form-group">
      <label for="lieuNaissance">Lieu de naissance:</label>
      <input type="text" name="lieuNaissance" required />
</div>
      <div class="form-group">
      <label for="sexe">Sexe:</label>
      <input type="text" name="sexe" required />
</div>
      <div class="form-group">
      <label for="codePostal">Code Postal:</label>
      <input type="text" name="codePostal" required />
</div>
      <div class="form-group">
      <label for="adresseLocale">Adresse locale:</label>
      <input type="text" name="adresseLocale" required />
</div>
      <div class="form-group">
      <label for="telephonePersonnel">Téléphone personnel:</label>
      <input type="text" name="telephonePersonnel" required />
</div>
      <div class="form-group">
      <label for="email">Adresse Email:</label>
      <input type="email" name="email" required />
</div>
      <div class="form-group">
      <label for="specialite">Spécialité:</label>
        </div>
      <div class="form-group">
      <select name="specialite" required>
        <option value="Licence en sciences de l'informatique">
          Licence en sciences de l'informatique
        </option>
        <option
          value="Licence en technologie des informations et communications (L-TIC)"
        >
          Licence en technologie des informations et communications (L-TIC)
        </option>
        <option value="Licence en mathématiques appliquées (L-M)">
          Licence en mathématiques appliquées (L-M)
        </option>
        <option
          value="Licence en électronique électrotechnique et automatique (L-EEA)"
        >
          Licence en électronique électrotechnique et automatique (L-EEA)
        </option>
        <option
          value="Licence en mesure et instrumentation et métrologie (L-MIM)"
        >
          Licence en mesure et instrumentation et métrologie (L-MIM)
        </option>
        <option value="Licence en systèmes embarqués (L-SE)">
          Licence en systèmes embarqués (L-SE)
        </option>
        <option value="Diplôme national d'ingénieur en électronique(ING)">
          Diplôme national d'ingénieur en électronique(ING)
        </option>
        <option value="Cycle préparatoire intégré (CPI)">
          Cycle préparatoire intégré (CPI)
        </option>
        <option
          value="Mastère de recherche en microélectronique et instrumentation (MR-micro)"
        >
          Mastère de recherche en microélectronique et instrumentation
          (MR-micro)
        </option>
        <option value="Mastère de recherche en génie logiciel (MR-GL)">
          Mastère de recherche en génie logiciel (MR-GL)
        </option>
        <option value="Mastère professionnel en génie logiciel (MP-GL)">
          Mastère professionnel en génie logiciel (MP-GL)
        </option>
        <option value="Mastère professionnel en Data Science (MPDS)">
          Mastère professionnel en Data Science (MPDS)
        </option>
      </select>
      </div>
            <div class="form-group">


      <label for="niveauEtudes">Niveau d'études:</label>
      <select name="niveauEtudes" required>
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
      </select>
      </div>
            <div class="form-group">

            
      <label for="groupeTD">Groupe TD:</label>
      <select name="groupeTD" required>
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
      </select>
      </div>
      <div class="form-group">
        <label for="etablissementAuPrecedente"
          >Etablissement de l’AU précédente:</label>
        <input type="text" name="etablissementAuPrecedente" required />
        </div>
      <div class="form-group">
      <button type="submit">Add Student</button>
      </div>
    </form>

    


<% var selectedSpecialite = "" %>

    <h2>Edit / Delete Students</h2>

    <!-- Specialization Filter -->
    <label for="specialiteFilter">Filter by Spécialité:</label>
    <select id="specialiteFilter" onchange="filterStudentsBySpecialite()">
        <option value="CPI1">CPI1</option>
        <option value="CPI2">CPI2</option>
        <option value="ING1EL">ING1EL</option>
        <option value="ING1INFO">ING1INFO</option>
        <option value="ING2INFO">ING2INFO</option>
        <option value="ING2EL">ING2EL</option>
        <option value="ING3INFO">ING3INFO</option>
        <option value="ING3EL">ING3EL</option>
        <option value="L1_EEA">L1_EEA</option>
        <option value="L1_INFO">L1_INFO</option>
        <option value="L1_MATH">L1_MATH</option>
        <option value="L1_TIC">L1_TIC</option>
        <option value="L2_INFO">L2_INFO</option>
        <option value="L2_MATH">L2_MATH</option>
        <option value="L2_MIM">L2_MIM</option>
        <option value="L2_SE">L2_SE</option>
        <option value="L2_TIC">L2_TIC</option>
        <option value="L3_INFO">L3_INFO</option>
        <option value="L3_MATH">L3_MATH</option>
        <option value="L3_SE">L3_SE</option>
        <option value="L3_TIC">L3_TIC</option>
        <option value="MP1_GL">MP1_GL</option>
        <option value="MP1_III">MP1_III</option>
        <option value="MP1_SD">MP1_SD</option>
        <option value="MP2_GL">MP2_GL</option>
        <option value="MP2_III">MP2_III</option>
        <option value="MP2_SD">MP2_SD</option>
        <option value="MR1_EL">MR1_EL</option>
        <option value="MR1_GL">MR1_GL</option>
        <option value="MR2_EL">MR2_EL</option>
        <option value="MR2_GL">MR2_GL</option>
      </select>

    <!-- List of Students -->
    <ul>
      <% students.forEach(student => { %>
      <!-- Check if the selected specialization matches -->
      <% if (!selectedSpecialite || student.specialite === selectedSpecialite) {
      %>
      <li data-specialite="<%= student.specialite %>">
        <%= student.nom %> <%= student.prenom %> - <%= student.specialite %>
        <!-- Adjust the displayed attributes -->

        <!-- Include other new attributes in your form -->

        <form
          action="/students/edit/<%= student._id %>"
          method="get"
          style="display: inline"
        >
          <button type="submit">Edit</button>
        </form>
        <form
          action="/students/delete/<%= student._id %>?_method=DELETE"
          method="post"
          style="display: inline"
        >
          <button type="submit">Delete</button>
        </form>
      </li>
      <% } %> <% }) %>
    </ul>

    <script>
      // JavaScript function to filter students by specialization
      function filterStudentsBySpecialite() {
        var selectElement = document.getElementById("specialiteFilter");
        var selectedSpecialite = selectElement.value;
        var studentListItems = document.querySelectorAll("ul li");

        // Hide/show students based on the selected specialization
        for (var i = 0; i < studentListItems.length; i++) {
          var student = studentListItems[i];
          var studentSpecialite = student.getAttribute("data-specialite"); // Extracting specialization from the data attribute

          // Show all students if no specialization is selected or the student's specialization matches the selected one
          if (!selectedSpecialite || studentSpecialite === selectedSpecialite) {
            student.style.display = "list-item";
          } else {
            student.style.display = "none";
          }
        }
      }
    </script>
  </body>
</html>
